# ========================================
# Smart Receipt Assistant 配置文件 / Configuration
# ========================================
# 复制此文件为 .env 并填入你的配置
# Copy this file to .env and fill in your configuration

# ----------------------------------------
# PaddleOCR 访问令牌 / Access Token (必填 / Required)
# ----------------------------------------
# 获取方式 / How to get:
# 1. 访问 PaddleOCR 官方网站 / Visit PaddleOCR official website: https://www.paddleocr.com
# 2. 完成注册 / Complete registration
# 3. 在模型服务页面点击"API"按钮 / Click "API" button on model service page
# 4. 可获得 PaddleOCR-VL-1.5 和 PP-OCRv5 的【TOKEN】和【API_URL】
#    Get TOKEN and API_URL for PaddleOCR-VL-1.5 and PP-OCRv5
#
# 此 Token 同时用于 / This token is used for both:
# - PaddleOCR-VL-1.5 OCR 识别（支持每天免费解析数万文档页数）
#   PaddleOCR-VL-1.5 OCR recognition (supports free parsing of tens of thousands of pages per day)
# - ERINE 大模型调用（与 PaddleOCR Token 一致，无需额外获取）
#   ERINE LLM (same token as PaddleOCR, no extra setup needed)
PADDLEOCR_ACCESS_TOKEN=your_paddleocr_token_here

# ----------------------------------------
# PaddleOCR API URL (必填 / Required)
# ----------------------------------------
# 从 PaddleOCR 官网 API 页面复制 / Copy from PaddleOCR official website API page
PADDLEOCR_API_URL=your_paddleocr_api_url_here

# ----------------------------------------
# ERINE API URL (可选，有默认值 / Optional, has default value)
# ----------------------------------------
# 如需修改，从 https://aistudio.baidu.com/playground 获取
# If you need to modify, get it from https://aistudio.baidu.com/playground
# ERINE_BASE_URL=https://aistudio.baidu.com/llm/lmapi/v3
